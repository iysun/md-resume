{
  "name": "md-resume",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,pdf -c blue,green \"npm run dev:web\" \"npm run dev:pdf\"",
    "dev:web": "vite",
    "dev:pdf": "PUPPETEER_CACHE_DIR=$HOME/.cache/puppeteer tsx server/pdf-server.ts",
    "build": "tsc -b && vite build",
    "postinstall": "if [ \"$PDF_SERVER\" = \"1\" ]; then PUPPETEER_CACHE_DIR=$HOME/.cache/puppeteer npx puppeteer browsers install chrome || true; fi",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@uiw/react-codemirror": "^4.25.10",
    "concurrently": "^9.2.1",
    "dompurify": "^3.4.5",
    "marked": "^18.0.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsx": "^4.22.3"
  },
  "optionalDependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "puppeteer": "^25.0.4",
    "puppeteer-core": "^25.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
